{
  "name": "imagii",
  "version": "1.0.0",
  "description": "imagii — local-first creative studio for video, audio, image, and AI art",
  "main": "./out/main/index.js",
  "author": "Makenah",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build:icon": "node scripts/build-icon.mjs",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "dist": "npm run build:icon && electron-vite build && electron-builder --win portable --config electron-builder.yml",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "file-type": "^19.6.0",
    "fluent-ffmpeg": "^2.1.3",
    "konva": "^9.3.22",
    "music-metadata": "^10.9.1",
    "nanoid": "^5.1.11",
    "path-browserify": "^1.0.1",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-konva": "^18.2.14",
    "react-rnd": "^10.5.3",
    "react-router-dom": "^6.26.0",
    "use-image": "^1.1.4",
    "wavesurfer.js": "^7.12.6",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20.14.0",
    "@types/path-browserify": "^1.0.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.39",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
